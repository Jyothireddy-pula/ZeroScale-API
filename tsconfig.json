{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false
  },
  "include": ["index.ts", "src/**/*.ts", "__tests__/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}